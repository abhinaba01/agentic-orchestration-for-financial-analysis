# ── Virtual Environment ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Environment Variables (NEVER commit these) ───────────────────────────────
.env
*.env

# ── Python Cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── ONNX Models (too large for git, download separately) ─────────────────────
models/
*.onnx

# ── ChromaDB Vector Store (generated at runtime) ─────────────────────────────
chroma_db/

# ── Pipeline Output Reports ───────────────────────────────────────────────────
output/

# ── Jupyter Notebook Checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE Files ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Test Input Documents ──────────────────────────────────────────────────────
*.pdf
*.htm
*.html

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Distribution / Packaging ─────────────────────────────────────────────────
dist/
build/
*.egg-info/*.onnx
models/
