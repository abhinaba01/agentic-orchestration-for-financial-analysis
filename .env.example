# OpenAI API key used for embedding and chat requests
OPENAI_API_KEY=your_openai_api_key_here

# Local directory for ChromaDB persistence
CHROMA_PERSIST_DIR=./chroma_db

# Path to the INT8 ONNX model used for named entity recognition
ONNX_NER_MODEL_PATH=./models/ner_int8.onnx

# Path to the INT8 ONNX model used for sentiment analysis
ONNX_SENTIMENT_MODEL_PATH=./models/sentiment_int8.onnx
